          },
          {
            "type": "object",
            "properties": {
              "children": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Section"
                }
              }
            }
          }
        ]
      },
      "Section": {
        "type": "object",
        "properties": {
          "id": {
