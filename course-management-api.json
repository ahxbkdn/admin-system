  "paths": {
    "/courses": {
      "post": {
        "summary": "创建课程",
        "description": "添加新课程",
        "tags": ["课程管理"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "课程标题"
                  },
                  "teacher": {
                    "type": "string",
                    "description": "课程主讲老师"
                  },
                  "totalHours": {
                    "type": "number",
                    "description": "总课时"
                  },
                  "description": {
                    "type": "string",
                    "description": "课程简介"
                  },
                  "price": {
                    "type": "number",
                    "description": "课程价格"
                  },
                  "category": {
                    "type": "string",
                    "description": "课程分类"
                  },
                  "status": {
                    "type": "string",
                    "description": "课程状态（draft/published/offline）"
                  },
                  "cover": {
                    "type": "string",
                    "description": "课程封面图URL"
                  }
                },
                "required": [
                  "title",
                  "teacher",
                  "totalHours",
                  "description",
                  "price",
                  "category",
                  "status"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "操作成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Course"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "获取课程列表",
        "description": "获取课程分页列表",
        "tags": ["课程管理"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "页码，默认1"
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "每页数量，默认10"
          },
          {
            "name": "title",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "课程标题搜索"
          },
          {
            "name": "teacher",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "老师名称搜索"
          },
          {
            "name": "category",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "课程分类搜索"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "课程状态搜索"
          }
        ],
        "responses": {
          "200": {
            "description": "操作成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "records": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Course"
                          }
                        },
                        "total": {
                          "type": "integer"
                        },
                        "size": {
                          "type": "integer"
                        },
                        "current": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
