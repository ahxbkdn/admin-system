          },
          "sort": {
            "type": "number"
          },
          "isFree": {
            "type": "boolean"
          },
          "videoUrl": {
            "type": "string"
          },
          "createTime": {
            "type": "string"
          },
          "updateTime": {
            "type": "string"
          }
        }
