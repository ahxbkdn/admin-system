# 忽略大压缩包
*.tgz
*.zip
*.rar

# 忽略Java编译后的jar包和target目录
**/target/
*.jar
# 日志文件
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 依赖目录
node_modules/

# 编译输出目录（看你项目需要，一般是 dist 或 build，如果要打包成品就保留，如果要上传源码就删）
# dist/
# build/

# 本地运行时的文件
.temp/
.tmp/

# 编辑器配置
.idea/
.vscode/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 缓存文件
*.pid
*.seed
*.pid.lock

# 其他不需要的
.env
.env.local
.env.development.local
.env.test.local
.env.production.local