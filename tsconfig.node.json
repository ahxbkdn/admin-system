{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true,
    "noUnusedLocals": false,  // 关闭未使用局部变量校验
    "noUnusedParameters": false  // 关闭未使用函数参数校验
  },
  "include": ["vite.config.ts"]
}
