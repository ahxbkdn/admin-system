          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string", "description": "课程标题" },
                  "teacher": { "type": "string", "description": "课程主讲老师" },
                  "totalHours": { "type": "number", "description": "总课时" },
                  "description": { "type": "string", "description": "课程简介" },
                  "price": { "type": "number", "description": "课程价格" },
                  "category": { "type": "string", "description": "课程分类" },
                  "status": { "type": "string", "description": "课程状态（draft/published/offline）" },
                  "cover": { "type": "string", "description": "课程封面图URL" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "操作成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number" },
                    "message": { "type": "string" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string" },
                        "title": { "type": "string" },
                        "teacher": { "type": "string" },
                        "totalHours": { "type": "number" },
                        "description": { "type": "string" },
                        "price": { "type": "number" },
                        "category": { "type": "string" },
                        "status": { "type": "string" },
                        "cover": { "type": "string" },
                        "createTime": { "type": "string" },
                        "updateTime": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "删除课程",
        "description": "根据ID删除课程",
        "tags": ["课程管理"],
        "parameters": [
          { "name": "id", "in": "path", "type": "string", "required": true, "description": "课程ID" }
        ],
        "responses": {
          "200": {
            "description": "操作成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number" },
                    "message": { "type": "string" },
                    "data": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/courses/{courseId}/chapters": {
      "post": {
        "summary": "添加章节",
        "description": "为课程添加章节",
        "tags": ["章节管理"],
        "parameters": [
          { "name": "courseId", "in": "path", "type": "string", "required": true, "description": "课程ID" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string", "description": "章节标题", "required": true },
                  "sort": { "type": "number", "description": "章节排序" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "操作成功",
