              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number" },
                    "message": { "type": "string" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "url": { "type": "string", "description": "上传文件的URL" }
                      }
