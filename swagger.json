{
  "openapi": "3.0.0",
  "info": {
    "title": "课程管理",
    "version": "1.0.0",
    "description": "课程管理系统后端接口文档"
  },
  "servers": [
    {
      "url": "http://120.55.194.16/api",
      "description": "课程管理系统后端服务器"
    }
  ],
  "paths": {
    "/courses": {
      "post": {
        "summary": "创建课程",
        "description": "添加新课程",
        "tags": ["课程管理"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string", "description": "课程标题", "required": true },
                  "teacher": { "type": "string", "description": "课程主讲老师", "required": true },
                  "totalHours": { "type": "number", "description": "总课时", "required": true },
                  "description": { "type": "string", "description": "课程简介", "required": true },
                  "price": { "type": "number", "description": "课程价格", "required": true },
                  "category": { "type": "string", "description": "课程分类", "required": true },
                  "status": { "type": "string", "description": "课程状态（draft/published/offline）", "required": true },
                  "cover": { "type": "string", "description": "课程封面图URL" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "操作成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number" },
                    "message": { "type": "string" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string" },
                        "title": { "type": "string" },
                        "teacher": { "type": "string" },
                        "totalHours": { "type": "number" },
                        "description": { "type": "string" },
                        "price": { "type": "number" },
                        "category": { "type": "string" },
                        "status": { "type": "string" },
                        "cover": { "type": "string" },
                        "createTime": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "获取课程列表",
        "description": "获取课程分页列表",
        "tags": ["课程管理"],
        "parameters": [
          { "name": "page", "in": "query", "type": "number", "description": "页码，默认1" },
          { "name": "size", "in": "query", "type": "number", "description": "每页数量，默认10" },
          { "name": "title", "in": "query", "type": "string", "description": "课程标题搜索" },
          { "name": "teacher", "in": "query", "type": "string", "description": "老师名称搜索" },
          { "name": "category", "in": "query", "type": "string", "description": "课程分类搜索" },
          { "name": "status", "in": "query", "type": "string", "description": "课程状态搜索" }
        ],
        "responses": {
          "200": {
            "description": "操作成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number" },
                    "message": { "type": "string" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "records": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": { "type": "string" },
                              "title": { "type": "string" },
                              "teacher": { "type": "string" },
                              "totalHours": { "type": "number" },
                              "price": { "type": "number" },
                              "category": { "type": "string" },
                              "status": { "type": "string" },
                              "createTime": { "type": "string" }
                            }
                          }
                        },
                        "total": { "type": "number" },
                        "size": { "type": "number" },
                        "current": { "type": "number" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
