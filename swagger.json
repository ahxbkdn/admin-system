          "title": { "type": "string" },
          "sort": { "type": "number" },
          "createTime": { "type": "string" },
          "updateTime": { "type": "string" },
          "children": { "type": "array", "items": { "$ref": "#/components/schemas/Section" } }
        }
      },
      "Section": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "chapterId": { "type": "string" },
          "title": { "type": "string" },
          "sort": { "type": "number" },
