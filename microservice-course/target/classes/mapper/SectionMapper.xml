<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.course.mapper.SectionMapper">
    <select id="getSectionsByChapterId" resultType="com.example.course.entity.Section">
        SELECT *
        FROM section
        WHERE chapter_id = #{chapterId}
        ORDER BY sort ASC
    </select>
</mapper>