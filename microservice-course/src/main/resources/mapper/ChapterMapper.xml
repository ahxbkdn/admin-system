<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.course.mapper.ChapterMapper">
    <select id="getChaptersByCourseId" resultType="com.example.course.entity.Chapter">
        SELECT *
        FROM chapter
        WHERE course_id = #{courseId}
        ORDER BY sort ASC
    </select>
</mapper>